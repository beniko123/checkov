pipeline {
     agent { label 'docker' }

    stages {
        stage('Checkout') {
            steps {
                git 'https://github.com/beniko123/checkov.git'
            }
        }

        stage('Install Checkov') {
            steps {
                sh '''
                pip3 install --upgrade checkov
                '''
            }
        }

        stage('Run Checkov Scan') {
            steps {
                sh '''
                checkov -d . --output cli
                '''
            }
        }
    }
}
